{
  "name": "sl2-map-react",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "slice-map": "node scripts/slice-map.js --input \"%MAP_INPUT%\" --outDir \"public/tiles\" --tileSize 800 --subfolderSize 6 --quality 75",
    "stitch-worldmaps": "node scripts/stitch-worldmaps.js --tilesDir \"public/tiles\" --tileSize 800 --gridWidth 47 --gridHeight 54 --subfolderSize 6 --format jpg --outDir \"public\"",
    "generate-cache-manifest": "node scripts/generate-cache-manifest.js"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.0.0",
    "sharp": "^0.33.5",
    "vite": "^5.0.0"
  }
}
